          "name": "Create Goal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"title\": \"Learn React\",\n  \"description\": \"Complete a React course\",\n  \"priority\": \"HIGH\",\n  \"status\": \"ACTIVE\",\n  \"dueDate\": \"2024-06-30\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/goal",
              "host": ["{{base_url}}"],
              "path": ["goal"]
