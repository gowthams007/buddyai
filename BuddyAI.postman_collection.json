{
  "info": {
    "name": "BuddyAI API",
    "version": "1.0.0",
    "description": "Personal AI Companion - Complete API Collection"
  },
  "item": [
    {
      "name": "Chat Endpoints",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"message\": \"What should I do today?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat",
              "host": ["{{base_url}}"],
              "path": ["chat"]
            }
          }
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/chat/history/1",
              "host": ["{{base_url}}"],
              "path": ["chat", "history", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Goal Endpoints",
      "item": [
