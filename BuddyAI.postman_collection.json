              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Learn React & Vue\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"MEDIUM\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/goal/1",
              "host": ["{{base_url}}"],
              "path": ["goal", "1"]
            }
          }
        },
        {
          "name": "Delete Goal",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/goal/1",
              "host": ["{{base_url}}"],
              "path": ["goal", "1"]
            }
          }
        }
      ]
    },
